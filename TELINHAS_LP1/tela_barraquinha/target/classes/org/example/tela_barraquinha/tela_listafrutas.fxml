<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.text.Font?>

<AnchorPane prefHeight="800.0" prefWidth="600.0"
            xmlns="http://javafx.com/javafx/25"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="org.example.tela_barraquinha.TelalistaController">

    <children>

        <Label layoutX="167.0" layoutY="54.0"
               text="Lista de frutas" underline="true">
            <font>
                <Font name="System Bold" size="40.0" />
            </font>
        </Label>

        <TableView fx:id="tabela_frutas"
                   layoutY="128.0"
                   prefHeight="583.0"
                   prefWidth="600.0">

            <columns>
                <TableColumn fx:id="col_nome" prefWidth="278.0" text="Nome" />
                <TableColumn fx:id="col_estado" prefWidth="120.0" text="Estado" />
                <TableColumn fx:id="col_quantidade" prefWidth="86.0" text="Quantidade" />
            </columns>

        </TableView>

        <Label layoutX="23.0" layoutY="14.0"
               text="Nome do cliente: ">
            <font>
                <Font name="System Bold" size="12.0" />
            </font>
        </Label>

        <Label fx:id="nome_cliente"
               layoutX="123.0" layoutY="14.0"
               prefHeight="17.0" prefWidth="447.0"
               text=""/>

        <Button fx:id="btn_sair"
                layoutX="51.0" layoutY="736.0"
                text="Sair"
                textFill="RED"
                onAction="#sair"/>

        <Button fx:id="btn_voltar"
                layoutX="251.0" layoutY="736.0"
                text="Voltar ao menu"
                onAction="#voltarMenu"/>

        <Button fx:id="btn_comprar"
                layoutX="510.0" layoutY="736.0"
                text="Comprar"
                onAction="#comprar"/>

    </children>
</AnchorPane>