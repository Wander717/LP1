<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Spinner?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.text.Font?>

<AnchorPane prefHeight="800.0" prefWidth="600.0" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="org.example.tela_barraquinha.controllers.MenuController">

   <children>

      <ImageView fitHeight="186.0" fitWidth="201.0" layoutX="207.0" layoutY="99.0" pickOnBounds="true" preserveRatio="true">
         <image>
            <Image url="@frutinhas.png" />
         </image>
      </ImageView>

      <Label layoutX="133.0" layoutY="28.0" text="Barraquinha do seu Zé" underline="true">
         <font>
            <Font size="35.0" />
         </font>
      </Label>

      <TextField fx:id="txtNomeCliente" layoutX="175.0" layoutY="322.0" prefHeight="25.0" prefWidth="251.0" promptText="Digite o nome do cliente aqui..." />

      <Button fx:id="btn_cadastrar" layoutX="225.0" layoutY="636.0" onAction="#CadastrarTudo" prefHeight="59.0" prefWidth="124.0" text="Cadastrar tudo" />

      <Button fx:id="btn_tabela" layoutX="189.0" layoutY="725.0" onAction="#irParaLista" prefHeight="35.0" prefWidth="186.0" text="Consultar tabela" />
      <ComboBox fx:id="cbFuncionario" layoutX="134.0" layoutY="511.0" prefHeight="26.0" prefWidth="296.0" promptText="Selecione o Funcionário que fez o atendimento" />
      <Spinner fx:id="spn_quant_fruta" layoutX="249.0" layoutY="456.0" prefHeight="26.0" prefWidth="75.0" />
      <Label layoutX="254.0" layoutY="431.0" text="Quantidade">
         <font>
            <Font name="System Bold" size="12.0" />
         </font>
      </Label>
      <TextField fx:id="txtNomeFruta" layoutX="175.0" layoutY="388.0" prefHeight="25.0" prefWidth="251.0" promptText="Digite o nome da fruta aqui..." />
      <Label layoutX="268.0" layoutY="361.0" text="Fruta">
         <font>
            <Font name="System Bold" size="12.0" />
         </font>
      </Label>
      <Label layoutX="267.0" layoutY="291.0" text="Cliente">
         <font>
            <Font name="System Bold" size="12.0" />
         </font>
      </Label>

   </children>
</AnchorPane>
