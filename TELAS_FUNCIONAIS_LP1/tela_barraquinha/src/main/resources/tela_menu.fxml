<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Spinner?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.text.Font?>

<AnchorPane prefHeight="800.0" prefWidth="600.0" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="org.example.tela_barraquinha.controllers.MenuController">

   <children>

      <ImageView fitHeight="186.0" fitWidth="201.0" layoutX="207.0" layoutY="99.0" pickOnBounds="true" preserveRatio="true">
         <image>
            <Image url="@frutinhas.png" />
         </image>
      </ImageView>

      <Label layoutX="255.0" layoutY="26.0" text="Menu" underline="true">
         <font>
            <Font size="35.0" />
         </font>
      </Label>

      <TextField fx:id="txt_NomeCliente" layoutX="175.0" layoutY="322.0" prefHeight="25.0" prefWidth="251.0" promptText="Digite o nome do cliente aqui..."  />

      <Button fx:id="btn_cadastrar" layoutX="234.0" layoutY="616.0" onAction="#CadastrarTudo" text="Cadastrar tudo" />

      <Button fx:id="btn_tabela" layoutX="189.0" layoutY="665.0" onAction="#irParaLista" prefHeight="35.0" prefWidth="186.0" text="Consultar tabela" />

      <Button fx:id="btn_sair" layoutX="264.0" layoutY="729.0" onAction="#sair" text="Sair" textFill="RED" />
      <ComboBox fx:id="combobox_selecionarfruta" layoutX="199.0" layoutY="439.0" prefHeight="25.0" prefWidth="199.0" promptText="Selecione o estado da fruta" />
      <Spinner fx:id="spn_quant_fruta" layoutX="244.0" layoutY="548.0" prefHeight="26.0" prefWidth="75.0" />
      <Label layoutX="249.0" layoutY="521.0" text="Quantidade">
         <font>
            <Font name="System Bold" size="12.0" />
         </font>
      </Label>
      <TextField fx:id="txt_NomeFruta" layoutX="175.0" layoutY="388.0" prefHeight="25.0" prefWidth="251.0" promptText="Digite o nome da fruta aqui..." />
      <Label text="Label" />
      <Label layoutX="268.0" layoutY="361.0" text="Fruta">
         <font>
            <Font name="System Bold" size="12.0" />
         </font>
      </Label>
      <Label layoutX="267.0" layoutY="291.0" text="Cliente">
         <font>
            <Font name="System Bold" size="12.0" />
         </font>
      </Label>

   </children>
</AnchorPane>
