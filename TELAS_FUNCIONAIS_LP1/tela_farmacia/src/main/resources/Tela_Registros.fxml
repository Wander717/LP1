<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.text.Font?>

<AnchorPane prefHeight="816.0" prefWidth="1327.0" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="org.example.tela_farmacia.controllers.RegistrosController">
   <children>
      <Label layoutX="588.0" layoutY="33.0" text="Registros" underline="true">
         <font>
            <Font name="System Bold" size="33.0" />
         </font>
      </Label>
      <TableView fx:id="tabela_Registros" layoutY="135.0" prefHeight="576.0" prefWidth="1327.0">
        <columns>
          <TableColumn fx:id="col_IdRegistro" prefWidth="88.0" text="Id" />
          <TableColumn fx:id="col_NomeCliente" prefWidth="300.0" text="Cliente" />
            <TableColumn fx:id="col_IdadeCliente" prefWidth="92.0" text="Idade" />
            <TableColumn fx:id="col_NomeRemedio" prefWidth="380.0" text="Remédio" />
            <TableColumn fx:id="col_TipoRemedio" prefWidth="116.0" text="Tipo" />
            <TableColumn fx:id="col_QuantRemedio" prefWidth="74.0" text="Quant" />
            <TableColumn fx:id="col_NomeFuncionario" prefWidth="276.0" text="Funcionário responsável" />
        </columns>
      </TableView>
      <Button fx:id="btnVoltarMenu" layoutX="29.0" layoutY="737.0" mnemonicParsing="false" onAction="#voltarMenu" prefHeight="49.0" prefWidth="145.0" text="Voltar ao Menu" />
      <Button fx:id="btnEditar" layoutX="710.0" layoutY="736.0" mnemonicParsing="false" onAction="#editarLinhaSelecionada" text="Editar Selecionado" />
      <Button fx:id="btnExcluir" layoutX="326.0" layoutY="736.0" mnemonicParsing="false" onAction="#excluirLinhaSelecionada" text="Excluir selecionado" />
      <Button fx:id="btnSalvar" layoutX="1124.0" layoutY="736.0" mnemonicParsing="false" onAction="#salvarAlteracoes" text="Salvar " />
   </children>
</AnchorPane>
