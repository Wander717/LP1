<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.text.Font?>

<AnchorPane prefHeight="787.0" prefWidth="1141.0" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="org.example.tela_salao.controllers.TabelaController">
   <children>
      <Label layoutX="452.0" layoutY="29.0" text="Controle de gastos" underline="true">
         <font>
            <Font name="System Bold" size="27.0" />
         </font>
      </Label>
      <TableView fx:id="tabelaGastos" layoutY="141.0" prefHeight="505.0" prefWidth="1141.0">
        <columns>
            <TableColumn fx:id="colunaId" prefWidth="61.0" text="ID" />
            <TableColumn fx:id="colunaFuncionario" prefWidth="225.0" text="Funcionário" />
            <TableColumn fx:id="colunaCliente" prefWidth="250.0" text="Cliente" />
            <TableColumn fx:id="colunaProduto" prefWidth="300.0" text="Produto" />
            <TableColumn fx:id="colunaTipo" prefWidth="213.0" text="Tipo" />
            <TableColumn fx:id="colunaQuantidade" prefWidth="91.0" text="Quant." />
        </columns>
      </TableView>
      <Button fx:id="btn_Voltar" layoutX="510.0" layoutY="680.0" mnemonicParsing="false" onAction="#voltarMenu" prefHeight="50.0" prefWidth="127.0" text="Voltar" />
      <Button fx:id="btn_Editar" layoutX="907.0" layoutY="680.0" mnemonicParsing="false" onAction="#editarItemSelecionado" prefHeight="50.0" prefWidth="163.0" text="Editar Item selecionado" />
      <Button fx:id="btn_Excluir" layoutX="88.0" layoutY="680.0" mnemonicParsing="false" onAction="#excluirLinhaSelecionada" prefHeight="50.0" prefWidth="176.0" text="Excluir Registro selecionado" />
   </children>
</AnchorPane>
