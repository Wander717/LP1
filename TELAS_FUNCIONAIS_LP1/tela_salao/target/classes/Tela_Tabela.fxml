<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.text.Font?>

<AnchorPane prefHeight="994.0" prefWidth="1628.0" xmlns="http://javafx.com/javafx/26" xmlns:fx="http://javafx.com/fxml/1" fx:controller="org.example.tela_salao.controllers.TabelaController">
   <children>
      <Label layoutX="761.0" layoutY="38.0" prefHeight="39.0" prefWidth="106.0" text="Estoque" underline="true">
         <font>
            <Font name="System Bold" size="27.0" />
         </font>
      </Label>
      <Button fx:id="btn_Voltar" layoutX="740.0" layoutY="900.0" mnemonicParsing="false" onAction="#voltarMenu" prefHeight="50.0" prefWidth="127.0" text="Voltar ao Menu" />
      <Button fx:id="btn_Editar" layoutX="1403.0" layoutY="900.0" mnemonicParsing="false" prefHeight="50.0" prefWidth="163.0" text="Editar Item selecionado" />
      <Button fx:id="btn_Excluir" layoutX="98.0" layoutY="900.0" mnemonicParsing="false" prefHeight="50.0" prefWidth="176.0" text="Excluir Registro selecionado" />
      <TableView fx:id="tabelaProduto" layoutX="-1.0" layoutY="186.0" prefHeight="486.0" prefWidth="1628.0">
         <columns>
            <TableColumn fx:id="idRegistro" prefWidth="84.0" text="ID Registro" />
            <TableColumn fx:id="nomeFuncionario" prefWidth="323.0" text="Funcionario" />
            <TableColumn fx:id="nomeProduto" prefWidth="445.0" text="Produto" />
            <TableColumn fx:id="tipoProduto" prefWidth="429.0" text="Tipo" />
            <TableColumn fx:id="quantProduto" prefWidth="113.0" text="Quantidade" />
            <TableColumn fx:id="dataRegistro" prefWidth="233.0" text="Data do Registro" />
         </columns>
      </TableView>
   </children>
</AnchorPane>
